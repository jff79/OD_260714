        <mxCell id="uOoNZgT5DBJ_roScs6Vi-12" value="4 - OPC GATF NFS de ficheros resultantes del cálculo" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="whhhZwCUR0vMInuOB5W6-1" vertex="1">
